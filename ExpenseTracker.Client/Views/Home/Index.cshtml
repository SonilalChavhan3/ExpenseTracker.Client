@{
    ViewData["Title"] = "Home Page";
}

<style>
    body {
        background-color: #f5f7fb;
    }

    .profile-img {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border: 4px solid #0d6efd;
    }

    .profile-card {
        transition: transform 0.3s ease;
    }

        .profile-card:hover {
            transform: translateY(-6px);
        }
</style>

<div class="container py-4">
    <div class="row g-4">

        <!-- Sonilal -->
        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            <div class="card profile-card shadow text-center h-100 rounded-4">
                <div class="card-body">
                    <img src="~/images/sonu.jpeg" class="rounded-circle profile-img mb-3" />
                    <h5 class="fw-bold">Sonilal Chavhan</h5>
                    <p class="text-muted">Senior Software Engineer</p>
                    <p class="text-muted">Ex VhaashTechnologies Pvt.LTD</p>
                    <ul class="list-group list-group-flush small text-start">
                        <li class="list-group-item"><strong>Age:</strong> 30</li>
                        <li class="list-group-item"><strong>Gender:</strong> Male</li>
                        <li class="list-group-item"><strong>City:</strong> Pune</li>
                    </ul>
                    <a asp-controller="Home" asp-action="SonilalChavhan"
                       class="btn btn-primary btn-sm w-100 rounded-pill mt-3">View Profile</a>
                </div>
            </div>
        </div>
<!-- Sonilal -->
        <!-- Amit -->
        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            <div class="card profile-card shadow text-center h-100 rounded-4">
                <div class="card-body">
                    <img src="~/images/amit.png" class="rounded-circle profile-img mb-3" />
                    <h5 class="fw-bold">Amit Linge</h5>
                    <p class="text-muted">Software Engineer</p>
                    <p class="text-muted">Square Vision Technologies</p>
                    <ul class="list-group list-group-flush small text-start">
                        <li class="list-group-item"><strong>Age:</strong> 27</li>
                        <li class="list-group-item"><strong>Gender:</strong> Male</li>
                        <li class="list-group-item"><strong>City:</strong> Pune</li>
                    </ul>
                    <a asp-controller="Home" asp-action="AmitLinge"
                       class="btn btn-primary btn-sm w-100 rounded-pill mt-3">View Profile</a>
                </div>
            </div>
        </div>
<!-- Amit -->
       
       

    </div>
</div>

